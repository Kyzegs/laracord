{
    "name": "kyzegs/laracord",
    "description": "Discord API wrapper",
    "license": "MIT",
    "keywords": [
        "discord"
    ],
    "authors": [
        {
            "name": "Sebastiaan \"Kyzegs\" Zegers",
            "email": "kyzegs@gmail.com"
        }
    ],
    "homepage": "https://github.com/Kyzegs/laracord",
    "autoload": {
        "psr-4": {
            "Kyzegs\\Laracord\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kyzegs\\Laracord\\Tests\\": "tests"
        }
    },
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "ext-sodium": "*",
        "guzzlehttp/guzzle": "^7.10",
        "illuminate/cache": "^12.0|^13.0",
        "illuminate/collections": "^12.0|^13.0",
        "illuminate/config": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/notifications": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "kyzegs/guzzle-rate-limit-middleware": "^1.1",
        "laravel/socialite": "^5.23"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1",
        "phpunit/phpunit": "^12.5",
        "phpstan/phpdoc-parser": "^1.16",
        "rector/rector": "^2.1",
        "driftingly/rector-laravel": "^2.0"
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage --min=85",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test",
        "ide-helpers": "php -f bin/resources.php",
        "ide-helpers:test": "php -f bin/resources.php -- --lint",
        "refactor:test": "vendor/bin/rector process --dry-run --no-progress-bar"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kyzegs\\Laracord\\ServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.3"
        }
    }
}
